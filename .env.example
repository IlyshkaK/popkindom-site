# Вариант 1 — одной строкой подключения, удобнее для Vercel/Supabase
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Вариант 2 — отдельными полями, если DATABASE_URL не используешь
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-password
DB_SSL=true

COOKIE_NAME=pd_session
COOKIE_SECURE=true
SESSION_HOURS=48
BCRYPT_ROUNDS=12
